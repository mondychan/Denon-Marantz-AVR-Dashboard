# Denon Dashboard Configuration
# Copy to .env and adjust values

# IP address of your Denon AVR receiver (leave empty for auto-discovery)
DENON_DASHBOARD_DENON_HOST=192.168.1.100

# Telnet control port (default: 23)
DENON_DASHBOARD_DENON_TELNET_PORT=23

# HEOS CLI port (default: 1255)
DENON_DASHBOARD_DENON_HEOS_PORT=1255

# Android TV / Google TV IP address (Remote protocol v2)
DENON_DASHBOARD_ANDROID_TV_HOST=

# Client name shown by Android TV during pairing
DENON_DASHBOARD_ANDROID_TV_CLIENT_NAME=Denon Dashboard

# Directory for Android TV pairing certificate/key
DENON_DASHBOARD_ANDROID_TV_STORAGE_DIR=/data/androidtv

# Optional Android TV ADB integration for screenshots, app launching and diagnostics.
# Requires ADB debugging enabled and authorized on the Android TV device.
DENON_DASHBOARD_ANDROID_TV_ADB_ENABLED=false
DENON_DASHBOARD_ANDROID_TV_ADB_PORT=5555
DENON_DASHBOARD_ANDROID_TV_ADB_STORAGE_DIR=/data/adb

# Display name for the receiver
DENON_DASHBOARD_DENON_DEVICE_NAME=Denon AVR

# Zone display names
DENON_DASHBOARD_DENON_ZONE1_NAME=Main Zone
DENON_DASHBOARD_DENON_ZONE2_NAME=Zone 2

# Custom source names as JSON (maps protocol codes to your display names)
# Find your source codes by checking the telnet output (SI? command)
# Common codes: GAME, BD, TV, SAT/CBL, MPLAY, NET, AUX1, AUX2, BT, CD, TUNER, DVD, PHONO
DENON_DASHBOARD_DENON_SOURCE_NAMES={}
# Example:
# DENON_DASHBOARD_DENON_SOURCE_NAMES={"GAME":"Game Console","TV":"TV Audio","BD":"Blu-ray","NET":"Streaming","AUX1":"PC/Console"}

# UI theme: gold (default), blue, red, green, olive, violet, purple, pink, orange
DENON_DASHBOARD_THEME=gold

# CORS allowed origins (default: * allows all). Comma-separated for multiple.
# DENON_DASHBOARD_CORS_ORIGINS=*

# Dashboard port (default: 8080)
# DENON_DASHBOARD_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
DENON_DASHBOARD_LOG_LEVEL=INFO
